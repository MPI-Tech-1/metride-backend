<!doctype html>
<html>

  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <title>
      Driver Account Approved
    </title>

    <style>
      @media only screen and (max-width: 620px) {
        table[class=body] p,
        table[class=body] td,
        table[class=body] span {
          font-size: 16px !important;
        }

        table[class=body] .wrapper {
          padding: 10px !important;
        }

        table[class=body] .container {
          width: 100% !important;
          padding: 0 !important;
        }
      }

      body,
      p {
        font-family: Arial, sans-serif;
      }

      .badge {
        background: #e8f5e9;
        border: 1px solid #4caf50;
        border-radius: 6px;
        padding: 16px 24px;
        margin: 25px 0;
        text-align: center;
      }

      .badge-text {
        font-size: 18px;
        font-weight: bold;
        color: #2e7d32;
      }
    </style>
  </head>

  <body style="background-color: #f6f6f6; margin: 0; padding: 0;">
    <table class="body" width="100%" style="background-color: #f6f6f6;">
      <tr>
        <td></td>
        <td class="container" width="580" style="margin: 0 auto; padding: 10px;">
          <div class="content" style="max-width: 580px; margin: 0 auto;">

            <table class="main" width="100%" style="background: #ffffff; border-radius: 6px;">

              <!-- HEADER BAR -->
              <tr style="background-color: #bb9267;">
                <td style="padding: 15px;"></td>
              </tr>

              <tr>
                <td style="padding: 25px 35px;">

                  <!-- LOGO -->
                  <img
                    src="https://res.cloudinary.com/dy4l3lrx1/image/upload/v1776506387/general/jnereh5fodzx08ejftds.png"
                    width="120"
                    style="display:block; border:none; outline:none;"
                    alt="logo"
                  />

                  <h2 style="color: #333; margin-top: 20px;">
                    Your Account Has Been Approved
                  </h2>

                  <p>
                    Hello {{ recipientFirstName }},
                  </p>

                  <p>
                    Great news! Your driver account application with <strong>{{ sentenceCase(env('BUSINESS_NAME')) }}</strong> has been reviewed and <strong style="color: #2e7d32;">approved</strong>.
                  </p>

                  <div class="badge">
                    <div class="badge-text">Account Approved ✓</div>
                  </div>

                  <p>
                    You can now log in to the app and start accepting ride requests. We're excited to have you on board!
                  </p>

                  <p>
                    If you have any questions or need assistance getting started, feel free to reach out to our support team.
                  </p>

                  <p>
                    Warm Regards,<br />
                    <strong>The {{ sentenceCase(env('BUSINESS_NAME')) }} Team</strong>
                  </p>

                </td>
              </tr>

              <!-- FOOTER -->
              <tr>
                <td style="padding: 20px 35px; background-color: #fafbfd;">
                  <p style="font-size: 11px; color: #666;">
                    Do not reply to this email as it was automatically generated.
                  </p>

                  <p style="font-size: 11px; color: #666;">
                    &copy; {{ currentYear() }} {{ sentenceCase(env('BUSINESS_NAME')) }}. All Rights Reserved.
                  </p>
                </td>
              </tr>

            </table>

          </div>
        </td>
        <td></td>
      </tr>
    </table>
  </body>

</html>
