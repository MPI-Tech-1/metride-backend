<!doctype html>
<html>

  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <title>
      Driver Account Application Update
    </title>

    <style>
      @media only screen and (max-width: 620px) {
        table[class=body] p,
        table[class=body] td,
        table[class=body] span {
          font-size: 16px !important;
        }
      
        table[class=body] .wrapper {
          padding: 10px !important;
        }
      
        table[class=body] .container {
          width: 100% !important;
          padding: 0 !important;
        }
      }
      
      body,
      p {
        font-family: Arial, sans-serif;
      }
      
      .reason-box {
        background: #fff8f0;
        border: 1px solid #bb9267;
        border-left: 4px solid #bb9267;
        border-radius: 6px;
        padding: 16px 20px;
        margin: 25px 0;
      }
      
      .reason-label {
        font-size: 12px;
        font-weight: bold;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
      }
      
      .reason-text {
        font-size: 15px;
        color: #333;
      }
    </style>
  </head>

  <body style="background-color: #f6f6f6; margin: 0; padding: 0;">
    <table class="body" width="100%" style="background-color: #f6f6f6;">
      <tr>
        <td>
        </td>
        <td class="container" width="580" style="margin: 0 auto; padding: 10px;">
          <div class="content" style="max-width: 580px; margin: 0 auto;">

            <table class="main" width="100%" style="background: #ffffff; border-radius: 6px;">

              <!-- HEADER BAR -->
              <tr style="background-color: #bb9267;">
                <td style="padding: 15px;">
                </td>
              </tr>

              <tr>
                <td style="padding: 25px 35px;">

                  <!-- LOGO -->
                  <img
                    src="https://res.cloudinary.com/dy4l3lrx1/image/upload/v1776506387/general/jnereh5fodzx08ejftds.png"
                    width="120"
                    style="display:block; border:none; outline:none;"
                    alt="logo"
                  />

                  <h2 style="color: #333; margin-top: 20px;">
                    Update on Your Driver Account Application
                  </h2>

                  <p>
                    Hello {{ recipientFirstName }},
                  </p>

                  <p>
                    Thank you for your interest in joining <strong>{{ sentenceCase(env('BUSINESS_NAME')) }}</strong>as a driver. After reviewing your application, we regret to inform you that we are unable to approve your account at this time.
                  </p>

                  <div class="reason-box">
                    <div class="reason-label">
                      Reason for Rejection
                    </div>
                    <div class="reason-text">
                      {{ rejectionReason }}
                    </div>
                  </div>

                  <p>
                    If you believe this decision was made in error or would like further clarification, please contact our support team and we will be happy to assist you.
                  </p>

                  <p>
                    We appreciate your time and understanding.
                  </p>

                  <p>
                    Warm Regards,<br />
                    <strong>The {{ sentenceCase(env('BUSINESS_NAME')) }} Team</strong>
                  </p>

                </td>
              </tr>

              <!-- FOOTER -->
              <tr>
                <td style="padding: 20px 35px; background-color: #fafbfd;">
                  <p style="font-size: 11px; color: #666;">
                    Do not reply to this email as it was automatically generated.
                  </p>

                  <p style="font-size: 11px; color: #666;">
                    &copy; {{ currentYear() }} {{ sentenceCase(env('BUSINESS_NAME')) }}. All Rights Reserved.
                  </p>
                </td>
              </tr>

            </table>

          </div>
        </td>
        <td>
        </td>
      </tr>
    </table>
  </body>

</html>
