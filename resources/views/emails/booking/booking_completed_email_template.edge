<!doctype html>
<html>

  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>
      Your trip receipt
    </title>
    <style>
      @media only screen and (max-width: 620px) {
        table[class=body] p,
        table[class=body] td,
        table[class=body] span {
          font-size: 16px !important;
        }
        table[class=body] .container {
          width: 100% !important;
          padding: 0 !important;
        }
      }
      body,
      p,
      td {
        font-family: Arial, Helvetica, sans-serif;
        color: #333333;
      }
      .receipt-pill {
        display: inline-block;
        background: #f8f4ef;
        border: 1px solid #bb9267;
        color: #6b4e2e;
        font-size: 11px;
        font-weight: bold;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 6px 14px;
        border-radius: 4px;
        margin-bottom: 8px;
      }
      .receipt-box {
        background: #fafbfd;
        border: 1px solid #e8e4df;
        border-radius: 8px;
        overflow: hidden;
        margin: 22px 0;
      }
      .receipt-row td {
        padding: 12px 18px;
        border-bottom: 1px solid #eeeeee;
        vertical-align: top;
      }
      .receipt-row:last-child td {
        border-bottom: none;
      }
      .label {
        font-size: 11px;
        font-weight: bold;
        color: #888888;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        width: 42%;
      }
      .value {
        font-size: 15px;
        color: #222222;
        line-height: 1.45;
      }
      .total-row td {
        background: #f8f4ef;
        border-top: 2px solid #bb9267;
        border-bottom: none !important;
        padding: 16px 18px;
      }
      .total-label {
        font-size: 12px;
        font-weight: bold;
        color: #6b4e2e;
        text-transform: uppercase;
        letter-spacing: 0.8px;
      }
      .total-amount {
        font-size: 24px;
        font-weight: bold;
        color: #bb9267;
        line-height: 1.2;
      }
      .muted {
        font-size: 12px;
        color: #777777;
        margin-top: 4px;
      }
    </style>
  </head>

  <body style="background-color: #f6f6f6; margin: 0; padding: 0;">
    <table class="body" width="100%" style="background-color: #f6f6f6;">
      <tr>
        <td></td>
        <td class="container" width="580" style="margin: 0 auto; padding: 10px;">
          <div class="content" style="max-width: 580px; margin: 0 auto;">
            <table class="main" width="100%" style="background: #ffffff; border-radius: 8px; border-collapse: separate;">

              <tr style="background-color: #bb9267;">
                <td style="padding: 14px 24px;"></td>
              </tr>

              <tr>
                <td style="padding: 28px 32px 8px;">

                  <img
                    src="https://res.cloudinary.com/dy4l3lrx1/image/upload/v1776506387/general/jnereh5fodzx08ejftds.png"
                    width="120"
                    style="display: block; border: none; outline: none;"
                    alt="{{ sentenceCase(env('BUSINESS_NAME')) }}"
                  />

                  <div style="margin-top: 22px;">
                    <span class="receipt-pill">Trip receipt</span>
                  </div>

                  <h1 style="color: #1a1a1a; font-size: 22px; font-weight: 700; margin: 12px 0 6px; line-height: 1.3;">
                    Your ride is complete
                  </h1>
                  <p style="margin: 0 0 18px; font-size: 15px; color: #555555;">
                    Hello {{ recipientFirstName }},
                  </p>
                  <p style="margin: 0 0 20px; font-size: 15px; line-height: 1.55; color: #444444;">
                    Thanks for riding with <strong>{{ sentenceCase(env('BUSINESS_NAME')) }}</strong>. Below is a summary of your trip for your records.
                  </p>

                  <div class="receipt-box">
                    <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">

                      <tr class="receipt-row">
                        <td class="label">Reference</td>
                        <td class="value" style="font-family: Consolas, Monaco, monospace; font-size: 14px;">{{ bookingReference }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Trip date</td>
                        <td class="value">{{ tripDate }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Receipt issued</td>
                        <td class="value">{{ receiptIssuedAt }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Service</td>
                        <td class="value">{{ rideTypeName }} · <span style="text-transform: capitalize;">{{ typeOfBooking }}</span></td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Pickup</td>
                        <td class="value">{{ departureLocationName }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Drop-off</td>
                        <td class="value">{{ destinationLocationName }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Est. distance</td>
                        <td class="value">{{ estimatedDistance }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Est. duration</td>
                        <td class="value">{{ estimatedDuration }}</td>
                      </tr>

                      @if(driverName)
                        <tr class="receipt-row">
                          <td class="label">Driver</td>
                          <td class="value">{{ driverName }}</td>
                        </tr>
                      @endif

                      <tr class="receipt-row">
                        <td class="label">Payment method</td>
                        <td class="value" style="text-transform: capitalize;">{{ paymentMethod }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Payment status</td>
                        <td class="value" style="text-transform: capitalize;">{{ paymentStatus }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Base fare</td>
                        <td class="value">{{ basePriceFormatted }}</td>
                      </tr>
                      <tr class="receipt-row">
                        <td class="label">Discount</td>
                        <td class="value">{{ discountFormatted }}</td>
                      </tr>

                      <tr class="total-row">
                        <td class="total-label" style="vertical-align: middle;">Total paid</td>
                        <td style="text-align: right; vertical-align: middle;">
                          <div class="total-amount">{{ amountPaidFormatted }}</div>
                          <div class="muted">Amount charged in Nigerian Naira (₦)</div>
                        </td>
                      </tr>
                    </table>
                  </div>

                  <p style="font-size: 15px; line-height: 1.55; color: #444444; margin: 0 0 16px;">
                    We hope to see you again soon. Open the app anytime to book your next ride.
                  </p>

                  <p style="margin: 0; font-size: 15px; color: #333333;">
                    Warm regards,<br />
                    <strong>The {{ sentenceCase(env('BUSINESS_NAME')) }} Team</strong>
                  </p>

                </td>
              </tr>

              <tr>
                <td style="padding: 20px 32px 28px; background-color: #fafbfd; border-top: 1px solid #eeeeee;">
                  <p style="font-size: 11px; color: #666666; margin: 0 0 8px; line-height: 1.5;">
                    This message is your trip receipt. Please keep it for your records. If you have questions about this charge, contact support through the app.
                  </p>
                  <p style="font-size: 11px; color: #666666; margin: 0;">
                    Do not reply to this email — it was sent automatically.
                  </p>
                  <p style="font-size: 11px; color: #666666; margin: 12px 0 0;">
                    &copy; {{ currentYear() }} {{ sentenceCase(env('BUSINESS_NAME')) }}. All rights reserved.
                  </p>
                </td>
              </tr>

            </table>
          </div>
        </td>
        <td></td>
      </tr>
    </table>
  </body>

</html>
