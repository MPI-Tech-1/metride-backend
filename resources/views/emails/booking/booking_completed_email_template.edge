<!doctype html>
<html>

  <head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <title>
      Thank You for Your Ride
    </title>

    <style>
      @media only screen and (max-width: 620px) {
        table[class=body] p,
        table[class=body] td,
        table[class=body] span {
          font-size: 16px !important;
        }
      
        table[class=body] .wrapper {
          padding: 10px !important;
        }
      
        table[class=body] .container {
          width: 100% !important;
          padding: 0 !important;
        }
      }
      
      body,
      p {
        font-family: Arial, sans-serif;
      }
      
      .trip-summary {
        background: #f8f4ef;
        border: 1px solid #bb9267;
        border-radius: 6px;
        padding: 20px 24px;
        margin: 25px 0;
      }
      
      .trip-row {
        display: flex;
        margin-bottom: 10px;
      }
      
      .trip-label {
        font-size: 12px;
        font-weight: bold;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 2px;
      }
      
      .trip-value {
        font-size: 15px;
        color: #333;
      }
    </style>
  </head>

  <body style="background-color: #f6f6f6; margin: 0; padding: 0;">
    <table class="body" width="100%" style="background-color: #f6f6f6;">
      <tr>
        <td>
        </td>
        <td class="container" width="580" style="margin: 0 auto; padding: 10px;">
          <div class="content" style="max-width: 580px; margin: 0 auto;">

            <table class="main" width="100%" style="background: #ffffff; border-radius: 6px;">

              <!-- HEADER BAR -->
              <tr style="background-color: #bb9267;">
                <td style="padding: 15px;">
                </td>
              </tr>

              <tr>
                <td style="padding: 25px 35px;">

                  <!-- LOGO -->
                  <img
                    src="https://res.cloudinary.com/dy4l3lrx1/image/upload/v1776506387/general/jnereh5fodzx08ejftds.png"
                    width="120"
                    style="display:block; border:none; outline:none;"
                    alt="logo"
                  />

                  <h2 style="color: #333; margin-top: 20px;">
                    Your Ride Is Complete!
                  </h2>

                  <p>
                    Hello {{ recipientFirstName }},
                  </p>

                  <p>
                    Thank you for choosing <strong>{{ sentenceCase(env('BUSINESS_NAME')) }}</strong>! We hope you had a safe and comfortable ride. Here's a summary of your trip:
                  </p>

                  <!-- TRIP SUMMARY -->
                  <div class="trip-summary">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding-bottom: 14px;">
                          <div class="trip-label">
                            From
                          </div>
                          <div class="trip-value">
                            {{ departureLocationName }}
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding-bottom: 14px;">
                          <div class="trip-label">
                            To
                          </div>
                          <div class="trip-value">
                            {{ destinationLocationName }}
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>
                          <div class="trip-label">
                            Amount Paid
                          </div>
                          <div class="trip-value" style="font-weight: bold; color: #bb9267;">
                            {{ amountPaid }}
                          </div>
                        </td>
                      </tr>
                    </table>
                  </div>

                  <p>
                    We'd love to have you on board again. Book your next ride anytime through the app.
                  </p>

                  <p>
                    Warm Regards,<br />
                    <strong>The {{ sentenceCase(env('BUSINESS_NAME')) }} Team</strong>
                  </p>

                </td>
              </tr>

              <!-- FOOTER -->
              <tr>
                <td style="padding: 20px 35px; background-color: #fafbfd;">
                  <p style="font-size: 11px; color: #666;">
                    Do not reply to this email as it was automatically generated.
                  </p>

                  <p style="font-size: 11px; color: #666;">
                    &copy; {{ currentYear() }} {{ sentenceCase(env('BUSINESS_NAME')) }}. All Rights Reserved.
                  </p>
                </td>
              </tr>

            </table>

          </div>
        </td>
        <td>
        </td>
      </tr>
    </table>
  </body>

</html>
